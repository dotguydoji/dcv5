```gitignore
# Dependencies
node_modules/
.pnpm-store/
.npm/
.yarn/

# Build outputs
dist/
build/
coverage/
.eslintcache

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.*
!.env.example

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
.env
requirements.txt.bak

# TypeScript/JavaScript
*.tsbuildinfo
*.js.map
*.ts.map

# Temporary files
*.tmp
*.temp
.DS_Store
```