```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.tsbuildinfo

# Environment variables
.env
.env.local
*.env.*

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Temporary files
*.tmp

# Python cache (if present)
__pycache__/
*.pyc
*.pyo
*.pyd

# Coverage reports
coverage/
htmlcov/
.coverage

# Testing
.mypy_cache/
.pytest_cache/

# OS generated
.DS_Store
Thumbs.db

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```