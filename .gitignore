```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
.next/
.nuxt/
public/

# Logs and temp files
*.log
*.tmp
*.swp

# Environment variables
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
venv/
.venv/
.env

# Coverage reports
coverage/
htmlcov/
.coverage

# OS generated files
.DS_Store
Thumbs.db

# Compiled/Binary files
*.exe
*.dll
*.so
*.dylib
*.class
*.o
*.obj
*.out

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst

# Testing
.mypy_cache/
.pytest_cache/
.jest/
coverage/

# Gradle
.gradle/
build/

# Maven
target/

# Ruby
.bundle/
Gemfile.lock

# Go
*.mod
*.sum

# Rust
target/
Cargo.lock

# Julia
julia-*/

# Zig
zig*/
```