```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.ts.map

# Environment variables
.env
.env.local
*.env.*

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# Python artifacts (if any Python in project)
__pycache__/
*.pyc
*.pyo
*.pyd

# Logs
*.log

# Coverage reports
coverage/
htmlcov/
.coverage

# OS generated files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp

# Testing
.mypy_cache/
.pytest_cache/
.nyc_output/
coverage/

# Bundler
.sass-cache/
*.rbc

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Debug
debug.log
*.stackdump

# User-specific
.vscode/settings.json
!.vscode/settings.json  # Allow if specifically needed

# Compiled JavaScript (if applicable)
lib/
out/
tmp/
```