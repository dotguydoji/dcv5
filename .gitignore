```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.ts.map

# Logs
*.log

# Environment variables
.env
.env.local
*.env.*

# IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Python artifacts (if any Python files exist in the project)
__pycache__/
*.pyc
*.pyo
*.pyd
*.py~
.Python

# Coverage reports
coverage/
htmlcov/
.coverage

# OS generated files
.DS_Store
Thumbs.db

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```