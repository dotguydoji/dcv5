```gitignore
# Dependencies
node_modules/
.pnpm-store/
.npm/
.yarn/

# Build outputs
dist/
build/
coverage/
.nyc_output/
.eslintcache

# Environment variables
.env
.env.local
.env.*
!.env.example

# IDE specific
.vscode/
.idea/
*.swp
*.swo
*.tmp

# OS generated files
.DS_Store
Thumbs.db

# Logs
*.log

# Python specific (if applicable)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.eggs/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage*
.nosetests*

# Node specific (if applicable)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
node_modules/
jspm_packages/
typings/
.tern-port
.tern-project
.nyc_output
coverage/
.nyc_output/
.eslintcache

# TypeScript specific (if applicable)
*.tsbuildinfo
*.js.map
*.jsx.map
*.ts.map
*.tsx.map

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage/

# nyc test coverage
.nyc_output/

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# Typescript output
*.tsbuildinfo
dist/
out/
out-tsc/

# Temporary folders
tmp/
temp/

# System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
```